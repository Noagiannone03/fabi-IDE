  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Fabi",
        "defaultIconTheme": "material-icon-theme",
        "preferences": {
          "workbench.colorTheme": "fabi-islands",
          "workbench.iconTheme": "material-icon-theme",
          "window.menuBarVisibility": "compact",
          "editor.fontFamily": "'JetBrains Mono', 'SF Mono', ui-monospace, monospace",
          "editor.fontSize": 13,
          "editor.fontWeight": "400",
          "editor.lineHeight": 1.2,
          "editor.fontLigatures": true,
          "editor.letterSpacing": 0,
          "terminal.integrated.fontFamily": "'JetBrains Mono', 'SF Mono', ui-monospace, monospace",
          "terminal.integrated.fontSize": 12.5,
          "terminal.integrated.fontWeight": "400",
          "terminal.integrated.fontWeightBold": "700",
          "terminal.integrated.lineHeight": 1.2,
          "files.autoSave": "afterDelay",
          "editor.minimap.enabled": true,
          "security.workspace.trust.enabled": false,
          "breadcrumbs.enabled": false,
          "ai-features.copilot.enabled": false,
          "ai-features.AiEnable.enableAI": true
        },
        "electron": {
          "splashScreenOptions": {
            "content": "resources/splash.html",
            "width": 560,
            "height": 360,
            "minDuration": 1500,
            "maxDuration": 30000
          },
          "showWindowEarly": false
        }
      }
    }
  }
