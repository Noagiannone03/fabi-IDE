    "fabi-branding": "0.0.0",
    "fabi-swarm": "0.0.0",
    "fabi-spaces": "0.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.72.2",
    "electron": "39.8.7",
    "electron-builder": "^24.13.3"
  },
  "scripts": {
    "bundle": "yarn rebuild && theia build --mode development",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "theia start --plugins=local-dir:plugins",
    "watch": "yarn rebuild && theia build --watch --mode development",
    "download:plugins": "theia download:plugins",
    "package": "yarn download:plugins && yarn bundle && electron-builder --publish never -c electron-builder.yml",
    "package:dir": "yarn download:plugins && yarn bundle && electron-builder --dir --publish never -c electron-builder.yml",
    "package:mac": "yarn download:plugins && yarn bundle && electron-builder --mac --publish never -c electron-builder.yml"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "PKief.material-icon-theme": "https://open-vsx.org/api/PKief/material-icon-theme/5.35.0/file/PKief.material-icon-theme-5.35.0.vsix",
    "alexdauenhauer.catppuccin-noctis-icons": "https://open-vsx.org/api/alexdauenhauer/catppuccin-noctis-icons/0.3.0/file/alexdauenhauer.catppuccin-noctis-icons-0.3.0.vsix"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Fabi",
        "defaultIconTheme": "material-icon-theme",
        "preferences": {
          "workbench.colorTheme": "fabi-islands",
          "workbench.iconTheme": "material-icon-theme",
          "files.autoSave": "afterDelay",
          "editor.minimap.enabled": true,
          "security.workspace.trust.enabled": false,
          "breadcrumbs.enabled": false
        },
        "electron": {
          "splashScreenOptions": {
            "content": "resources/splash.html",
            "width": 560,
            "height": 360,
            "minDuration": 1500,
            "maxDuration": 30000
          },
          "showWindowEarly": false
        }
      }
    }
  }
}
