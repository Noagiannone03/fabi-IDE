  "scripts": {
    "bundle": "yarn download:plugins && yarn rebuild && theia build --mode development",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "yarn download:plugins && theia start --plugins=local-dir:plugins",
    "watch": "yarn download:plugins && yarn rebuild && theia build --watch --mode development",
    "download:plugins": "theia download:plugins",
    "package": "yarn download:plugins && yarn bundle && electron-builder --publish never -c electron-builder.yml",
    "package:dir": "yarn download:plugins && yarn bundle && electron-builder --dir --publish never -c electron-builder.yml",
    "package:mac": "yarn download:plugins && yarn bundle && electron-builder --mac --publish never -c electron-builder.yml"
  },
  "theiaPluginsDir": "plugins",
