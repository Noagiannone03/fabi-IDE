    "@theia/mini-browser": "1.72.2",
    "@theia/monaco": "1.72.2",
    "@theia/navigator": "1.72.2",
    "@theia/outline-view": "1.72.2",
    "@theia/output": "1.72.2",
    "@theia/plugin-ext": "1.72.2",
    "@theia/plugin-ext-vscode": "1.72.2",
