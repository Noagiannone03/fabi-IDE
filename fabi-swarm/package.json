{
  "name": "fabi-swarm",
  "keywords": [
    "theia-extension"
  ],
  "version": "0.1.0",
  "description": "Fabi Swarm — provider d'inférence LLM P2P (Parallax) branché dans Theia AI",
  "author": "Noa Giannone",
  "license": "MIT",
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
    "@theia/ai-chat": "1.72.2",
    "@theia/ai-chat-ui": "1.72.2",
    "@theia/ai-core": "1.72.2",
    "@theia/ai-ide": "1.72.2",
    "@theia/ai-openai": "1.72.2",
    "@theia/core": "1.72.2",
    "@theia/editor": "1.72.2",
    "@theia/terminal": "1.72.2",
    "@theia/workspace": "1.72.2",
    "lucide-react": "^1.18.0",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "~5.4.5"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf lib",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
